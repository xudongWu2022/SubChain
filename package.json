{
  "name": "subchain",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "contracts",
    "apps/web",
    "apps/indexer"
  ],
  "scripts": {
    "db:local": "powershell -ExecutionPolicy Bypass -File scripts/db-local.ps1",
    "db:local:reset": "powershell -ExecutionPolicy Bypass -File scripts/db-local.ps1 -Reset",
    "db:local:stop": "powershell -ExecutionPolicy Bypass -File scripts/db-local.ps1 -Stop",
    "dev:stack": "powershell -ExecutionPolicy Bypass -File scripts/dev-stack.ps1",
    "dev:stack:no-web": "powershell -ExecutionPolicy Bypass -File scripts/dev-stack.ps1 -NoWeb",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "dev:local:no-web": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1 -NoWeb",
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "dev:indexer": "npm run dev --workspace apps/indexer",
    "build:indexer": "npm run build --workspace apps/indexer",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:deploy:local": "cd contracts && forge script script/Deploy.s.sol --rpc-url http://127.0.0.1:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
