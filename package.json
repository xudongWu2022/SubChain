{
  "name": "subchain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "workspaces": [
    "contracts",
    "apps/web",
    "apps/indexer",
    "apps/service-agent",
    "apps/agent"
  ],
  "scripts": {
    "preflight": "node scripts/preflight.mjs",
    "launch:check-secrets": "node scripts/launch-check-secrets.mjs",
    "docs:gate": "node scripts/docs-gate.mjs",
    "validation:summary": "node scripts/validation-summary.mjs",
    "protocol:canary": "node scripts/protocol-canary.mjs",
    "test:all": "node scripts/test-all.mjs",
    "dev:local:cross": "node scripts/dev-local.mjs",
    "deploy:testnet": "node scripts/deploy-network.mjs testnet",
    "deploy:production": "node scripts/deploy-network.mjs production",
    "db:local": "powershell -ExecutionPolicy Bypass -File scripts/db-local.ps1",
    "db:local:reset": "powershell -ExecutionPolicy Bypass -File scripts/db-local.ps1 -Reset",
    "db:local:stop": "powershell -ExecutionPolicy Bypass -File scripts/db-local.ps1 -Stop",
    "dev:stack": "powershell -ExecutionPolicy Bypass -File scripts/dev-stack.ps1",
    "dev:stack:no-web": "powershell -ExecutionPolicy Bypass -File scripts/dev-stack.ps1 -NoWeb",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "dev:local:no-web": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1 -NoWeb",
    "dev:web": "pnpm --filter @subchain/web run dev",
    "build:web": "pnpm --filter @subchain/web run build",
    "lint:web": "pnpm --filter @subchain/web run lint",
    "dev:indexer": "pnpm --filter @subchain/indexer run dev",
    "build:indexer": "pnpm --filter @subchain/indexer run build",
    "dev:service": "pnpm --filter @subchain/service-agent run dev",
    "dev:agent": "pnpm --filter @subchain/agent run dev",
    "agent:cycle": "pnpm --filter @subchain/agent run cycle",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:deploy:local": "cd contracts && forge script script/Deploy.s.sol --rpc-url http://127.0.0.1:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.5.4"
  }
}
